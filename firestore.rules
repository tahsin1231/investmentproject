rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Document Rules
    match /users/{userId} {
      // Allow user to fetch or modify their own account profile
      allow get: if isSignedIn();
      allow list: if false; // Block all query scraping and listing
      allow create, update, delete: if isOwner(userId);

      // Active Plans Subcollection Rules
      match /activePlans/{planId} {
        allow read, write: if isOwner(userId);
      }

      // Transactions Subcollection Rules
      match /transactions/{txId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
